---
// IntakeForm.astro — confidential intake form with labeled fields
---

<section class="bg-paper py-xxl border-t border-border-subtle" id="intake">
  <div class="max-w-reading-width mx-auto px-gutter">

    <!-- Section header -->
    <div class="mb-xl text-center">
      <div class="signature-rule mx-auto"></div>
      <h2 class="font-headline-md text-headline-md text-primary mb-sm">Consulta Confidencial</h2>
      <p class="font-metadata text-metadata text-steel uppercase">FORMULARIO DE ADMISIÓN · PROTOCOLO SEGURO</p>
    </div>

    <!-- TODO: wire backend / Netlify Forms / Formspree before launch -->
    <form
      class="space-y-xl bg-warm-white p-xl border border-border-subtle"
      action=""
      method="post"
    >

      <!-- Section 01: Datos del solicitante -->
      <div>
        <h3 class="font-metadata text-metadata text-steel mb-lg pb-sm border-b border-border-subtle">
          01 DATOS DEL SOLICITANTE
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">

          <div class="flex flex-col">
            <label
              for="nombre"
              class="font-label-sm text-label-sm text-on-surface-variant uppercase mb-xs"
            >
              Nombre Completo
            </label>
            <input
              id="nombre"
              name="nombre"
              type="text"
              autocomplete="name"
              class="bg-transparent border border-border-subtle rounded-none p-sm font-body-md text-primary w-full"
            />
          </div>

          <div class="flex flex-col">
            <label
              for="entidad"
              class="font-label-sm text-label-sm text-on-surface-variant uppercase mb-xs"
            >
              Entidad / Organización
            </label>
            <input
              id="entidad"
              name="entidad"
              type="text"
              autocomplete="organization"
              class="bg-transparent border border-border-subtle rounded-none p-sm font-body-md text-primary w-full"
            />
          </div>

          <div class="flex flex-col md:col-span-2">
            <label
              for="correo"
              class="font-label-sm text-label-sm text-on-surface-variant uppercase mb-xs"
            >
              Correo Electrónico Seguro
            </label>
            <input
              id="correo"
              name="correo"
              type="email"
              autocomplete="email"
              class="bg-transparent border border-border-subtle rounded-none p-sm font-body-md text-primary w-full"
            />
          </div>

        </div>
      </div>

      <!-- Section 02: Naturaleza del caso -->
      <div>
        <h3 class="font-metadata text-metadata text-steel mb-lg pb-sm border-b border-border-subtle">
          02 NATURALEZA DEL CASO
        </h3>
        <div class="flex flex-col">
          <label
            for="descripcion"
            class="font-label-sm text-label-sm text-on-surface-variant uppercase mb-xs"
          >
            Breve Descripción (Evite detalles sensibles)
          </label>
          <textarea
            id="descripcion"
            name="descripcion"
            rows="4"
            class="bg-transparent border border-border-subtle rounded-none p-sm font-body-md text-primary w-full resize-none"
          ></textarea>
        </div>
      </div>

      <!-- Submit -->
      <div class="pt-lg border-t border-border-subtle flex justify-end">
        <button
          type="submit"
          class="bg-ink-blue text-on-primary font-label-caps text-label-caps px-xl py-md rounded-none uppercase hover:bg-ink-hover transition-colors duration-150 w-full md:w-auto"
        >
          Transmitir Solicitud
        </button>
      </div>

    </form>

    <!-- Mono confidentiality notice -->
    <p class="font-metadata text-metadata text-steel uppercase text-center mt-md">
      TODA LA INFORMACIÓN RECIBIDA ES ESTRICTAMENTE CONFIDENCIAL · PROTOCOLO SSL/TLS ACTIVO
    </p>

  </div>
</section>
