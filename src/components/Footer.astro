---
// Footer.astro — wordmark + tagline + footer links + compliance strip
---

<footer class="w-full bg-paper border-t border-outline-variant" role="contentinfo">

  <!-- Top row: wordmark + links -->
  <div class="px-gutter py-xl flex flex-col md:flex-row justify-between items-start gap-md max-w-max-width mx-auto">

    <div class="flex flex-col gap-sm">
      <span class="font-headline-sm text-headline-sm font-bold text-primary">
        Jimenez Intelligence Group
      </span>
      <span class="font-tagline text-lg italic text-on-surface-variant">
        "La verdad no se adivina. Se investiga."
      </span>
    </div>

    <ul class="flex flex-wrap gap-xl font-label-caps text-label-caps text-on-surface-variant">
      <li>
        <a
          class="hover:text-primary transition-colors duration-150 uppercase"
          href={import.meta.env.BASE_URL.replace(/\/$/, "") + "/libro/"}
        >
          El Libro
        </a>
      </li>
      <li>
        <a
          class="hover:text-primary transition-colors duration-150 uppercase"
          href="#"
          aria-label="Privacidad (próximamente)"
        >
          {/* TODO: real route when privacy page exists */}
          Privacidad
        </a>
      </li>
      <li>
        <a
          class="hover:text-primary transition-colors duration-150 uppercase"
          href="#"
          aria-label="OSINT Protocol (próximamente)"
        >
          {/* TODO: real route when OSINT protocol page exists */}
          OSINT Protocol
        </a>
      </li>
      <li>
        <a
          class="hover:text-primary transition-colors duration-150 uppercase"
          href="#"
          aria-label="Dossier (próximamente)"
        >
          {/* TODO: real route when dossier page exists */}
          Dossier
        </a>
      </li>
    </ul>

  </div>

  <!-- Bottom compliance strip -->
  <div class="w-full border-t border-border-subtle py-sm px-gutter">
    <p class="font-metadata text-metadata text-center text-steel uppercase max-w-max-width mx-auto">
      © 2026 JIMENEZ INTELLIGENCE GROUP · CLEWISTON, FL · TODOS LOS DERECHOS RESERVADOS
    </p>
  </div>

</footer>
