---
// Nav.astro — sticky navigation bar
const home = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
---

<nav
  class="sticky top-0 z-50 w-full flex justify-between items-center px-gutter py-sm max-w-max-width mx-auto bg-surface border-b border-outline-variant"
  role="navigation"
  aria-label="Navegación principal"
>
  <!-- Wordmark -->
  <a
    class="font-headline-sm text-headline-sm font-bold text-primary dark:text-primary-fixed-dim"
    href={home}
  >
    Jimenez Intelligence Group
  </a>

  <!-- Desktop links -->
  <div class="hidden md:flex items-center gap-lg">
    <ul class="flex gap-md font-label-caps text-label-caps">
      <li>
        <a
          class="text-on-surface-variant hover:text-ink-hover transition-colors duration-150 uppercase"
          href="#servicios"
        >
          Servicios
        </a>
      </li>
      <li>
        <a
          class="text-on-surface-variant hover:text-ink-hover transition-colors duration-150 uppercase"
          href="#director"
        >
          Sobre JIG
        </a>
      </li>
      <li>
        <a
          class="text-on-surface-variant hover:text-ink-hover transition-colors duration-150 uppercase"
          href="#"
          aria-label="Recursos (próximamente)"
        >
          {/* TODO: real route when resources page exists */}
          Recursos
        </a>
      </li>
      <li>
        <a
          class="text-on-surface-variant hover:text-ink-hover transition-colors duration-150 uppercase"
          href="#intake"
        >
          Contacto
        </a>
      </li>
    </ul>
    <a
      class="bg-ink-blue text-on-primary font-label-caps text-label-caps px-md py-sm rounded-none uppercase hover:bg-ink-hover transition-colors duration-150"
      href="#intake"
    >
      Consulta confidencial
    </a>
  </div>

  <!-- Mobile hamburger -->
  <button
    id="nav-hamburger"
    class="md:hidden text-primary"
    aria-label="Abrir menú de navegación"
    aria-expanded="false"
    aria-controls="mobile-menu"
    type="button"
  >
    <!-- Inline SVG hamburger: 3-line 24×24 currentColor -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <line x1="3" y1="6" x2="21" y2="6" />
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="18" x2="21" y2="18" />
    </svg>
  </button>
</nav>

<!-- Mobile menu panel — toggled by JS below -->
<div
  id="mobile-menu"
  class="hidden md:hidden w-full bg-surface border-b border-outline-variant px-gutter py-md"
>
  <ul class="flex flex-col gap-md font-label-caps text-label-caps">
    <li>
      <a class="text-on-surface-variant hover:text-ink-hover transition-colors duration-150 uppercase" href="#servicios">Servicios</a>
    </li>
    <li>
      <a class="text-on-surface-variant hover:text-ink-hover transition-colors duration-150 uppercase" href="#director">Sobre JIG</a>
    </li>
    <li>
      <a
        class="text-on-surface-variant hover:text-ink-hover transition-colors duration-150 uppercase"
        href="#"
        aria-label="Recursos (próximamente)"
      >
        {/* TODO: real route when resources page exists */}
        Recursos
      </a>
    </li>
    <li>
      <a class="text-on-surface-variant hover:text-ink-hover transition-colors duration-150 uppercase" href="#intake">Contacto</a>
    </li>
    <li class="pt-md border-t border-outline-variant">
      <a
        class="bg-ink-blue text-on-primary font-label-caps text-label-caps px-md py-sm rounded-none uppercase hover:bg-ink-hover transition-colors duration-150 inline-block"
        href="#intake"
      >
        Consulta confidencial
      </a>
    </li>
  </ul>
</div>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburger.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
