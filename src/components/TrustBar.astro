---
// TrustBar.astro — 3-cell horizontal strip with mono labels + Playfair values
---

<div class="bg-warm-white border-y border-border-subtle">
  <div class="max-w-max-width mx-auto px-gutter py-lg">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-lg divide-y md:divide-y-0 md:divide-x divide-border-subtle">

      <div class="flex flex-col items-center text-center pt-md md:pt-0 px-md">
        <span class="font-metadata text-metadata text-steel mb-unit">OPERACIONES</span>
        <span class="font-headline-sm text-headline-sm text-primary">FLORIDA · USA</span>
      </div>

      <div class="flex flex-col items-center text-center pt-md md:pt-0 px-md">
        <span class="font-metadata text-metadata text-steel mb-unit">TRAYECTORIA</span>
        <span class="font-headline-sm text-headline-sm text-primary">30+ AÑOS DE OFICIO</span>
      </div>

      <div class="flex flex-col items-center text-center pt-md md:pt-0 px-md">
        <span class="font-metadata text-metadata text-steel mb-unit">EXPERIENCIA</span>
        <span class="font-headline-sm text-headline-sm text-primary">EST. 1989</span>
      </div>

    </div>
  </div>
</div>
